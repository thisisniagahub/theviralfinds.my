DATABASE_URL=file:/home/z/my-project/db/custom.db

# NextAuth.js Configuration
NEXTAUTH_SECRET="theviralfindsmy-secret-key-2025"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (leave empty to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ─── Social Media Platform API Credentials (Task 1.2) ───────────────────────
# All leave empty by default → social account connections run in DEMO MODE.
# When real values are provided, /api/social/connect/[platform] will redirect
# to the platform's OAuth authorize URL and /api/social/callback/[platform]
# will exchange the code for a real access token.

# Facebook Graph API (used for both Facebook Page posts AND Instagram Business posts)
# https://developers.facebook.com/apps → Create App → Add "Facebook Login" + "Pages"
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# Instagram Graph API (falls back to FACEBOOK_APP_ID if INSTAGRAM_APP_ID is empty)
# Instagram uses the same underlying Graph API as Facebook.
INSTAGRAM_APP_ID=""

# TikTok Login Kit (only needed for direct video upload; we use a share-URL fallback)
# https://developers.tiktok.com → Create app → Login Kit
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# Twitter / X API v2 (OAuth 2.0 with PKCE)
# https://developer.twitter.com → Create app → OAuth 2.0 → confidential client
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""

# Optional shared-secret for the /api/social/execute cron endpoint
# (If unset, the endpoint is open — fine for dev, lock down in prod.)
SOCIAL_CRON_API_KEY=""
