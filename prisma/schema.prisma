generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────

enum LinkStatus {
  active
  paused
  expired
}

enum CampaignStatus {
  active
  paused
  completed
}

enum ConversionStatus {
  pending
  confirmed
  rejected
  paid
}

enum PayoutStatus {
  pending
  processing
  completed
  failed
}

enum GoalStatus {
  active
  achieved
  failed
}

enum GoalPeriod {
  monthly
  weekly
  yearly
  custom
}

enum UserRole {
  admin
  affiliate
  viewer
}

enum HermesSkillStatus {
  active
  draft
  archived
  learning
}

// ─── Models ─────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String   @default("demo")
  role          UserRole @default(affiliate)
  avatarUrl     String?
  shopeeAffId   String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  links         AffiliateLink[]
  clickRecords  ClickRecord[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model AffiliateLink {
  id                String        @id @default(cuid())
  name              String
  productUrl        String
  affiliateUrl      String
  productId         String?
  productName       String?
  productImage      String?
  productPrice      Decimal?
  commission        Decimal?
  commissionRate    Decimal?      @default(5)
  category          String?
  campaignId        String?
  userId            String?
  clicks            Int           @default(0)
  conversions       Int           @default(0)
  earnings          Decimal       @default(0)
  ctr               Decimal?      @default(0)
  status            LinkStatus    @default(active)
  shortCode         String        @unique
  expiresAt         DateTime?
  tags              String?
  campaign          Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  user              User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  clickRecords      ClickRecord[]
  conversionRecords Conversion[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status])
  @@index([campaignId])
  @@index([category])
  @@index([createdAt])
  @@index([userId])
  @@map("affiliate_links")
}

model Campaign {
  id          String          @id @default(cuid())
  name        String
  description String?
  status      CampaignStatus  @default(active)
  budget      Decimal?
  spent       Decimal         @default(0)
  startDate   DateTime?
  endDate     DateTime?
  links       AffiliateLink[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status])
  @@map("campaigns")
}

model ClickRecord {
  id            String        @id @default(cuid())
  linkId        String
  userId        String?
  affiliateLink AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  ip            String?
  country       String?
  referer       String?
  device        String?
  browser       String?
  os            String?
  converted     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([linkId])
  @@index([createdAt])
  @@index([device])
  @@index([converted])
  @@index([country])
  @@map("click_records")
}

model Conversion {
  id            String          @id @default(cuid())
  linkId        String
  affiliateLink AffiliateLink   @relation(fields: [linkId], references: [id], onDelete: Cascade)
  orderId       String?
  amount        Decimal
  commission    Decimal
  status        ConversionStatus @default(pending)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([linkId])
  @@index([status])
  @@index([createdAt])
  @@map("conversions")
}

model Payout {
  id          String       @id @default(cuid())
  userId      String?
  method      String       @default("bank_transfer")
  amount      Decimal
  status      PayoutStatus @default(pending)
  bankName    String?
  accountNo   String?
  accountName String?
  requestedAt DateTime     @default(now())
  processedAt DateTime?
  note        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([requestedAt])
  @@map("payouts")
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model EarningGoal {
  id            String     @id @default(cuid())
  name          String
  targetAmount  Decimal
  currentAmount Decimal    @default(0)
  period        GoalPeriod @default(monthly)
  startDate     DateTime   @default(now())
  endDate       DateTime?
  status        GoalStatus @default(active)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status])
  @@index([period])
  @@map("earning_goals")
}

model Notification {
  id          String   @id @default(cuid())
  type        String   @default("system")
  title       String
  description String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([read])
  @@index([createdAt])
  @@index([type])
  @@map("notifications")
}

model AgentMemory {
  id        String   @id @default(cuid())
  agentId   String
  sessionId String?
  role      String
  content   String
  metadata  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("agent_memories")
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String?
  type        String
  title       String
  description String
  icon        String
  earnedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([earnedAt])
  @@map("achievements")
}

model LeaderboardEntry {
  id               String   @id @default(cuid())
  userId           String?
  userName         String
  totalEarnings    Decimal  @default(0)
  totalClicks      Int      @default(0)
  totalConversions Int      @default(0)
  period           String
  rank             Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([period])
  @@index([rank])
  @@unique([userId, period])
  @@map("leaderboard_entries")
}

model Referral {
  id            String    @id @default(cuid())
  referrerId    String?
  referredEmail String
  referredName  String?
  status        String    @default("pending")
  commission    Decimal?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([referrerId])
  @@index([status])
  @@map("referrals")
}

// ─── Hermes Agent Models ────────────────────────────────────────

model HermesConnection {
  id            String   @id @default(cuid())
  name          String
  endpoint      String
  apiKey        String?
  model         String   @default("hermes-3")
  isActive      Boolean  @default(false)
  lastConnected DateTime?
  status        String   @default("disconnected")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("hermes_connections")
}

model HermesConversation {
  id            String   @id @default(cuid())
  connectionId  String
  title         String
  summary       String?
  messageCount  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages HermesMessage[]

  @@index([connectionId])
  @@index([createdAt])
  @@map("hermes_conversations")
}

model HermesMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // system, user, assistant
  content        String
  tokens         Int?
  metadata       String?  // JSON
  createdAt      DateTime @default(now())

  conversation HermesConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("hermes_messages")
}

model HermesSkill {
  id          String            @id @default(cuid())
  name        String
  description String
  category    String
  code        String
  trigger     String?
  status      HermesSkillStatus @default(draft)
  usageCount  Int               @default(0)
  successRate Decimal?          @default(0)
  version     Int               @default(1)
  learnedFrom String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([category])
  @@index([status])
  @@map("hermes_skills")
}

model HermesTask {
  id           String   @id @default(cuid())
  name         String
  description  String?
  schedule     String?  // cron expression
  skillId      String?
  status       String   @default("scheduled") // scheduled, running, completed, failed
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  runCount     Int      @default(0)
  lastResult   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([nextRunAt])
  @@map("hermes_tasks")
}

model HermesInsight {
  id          String   @id @default(cuid())
  type        String   // trend, opportunity, alert, recommendation
  title       String
  description String
  severity    String   @default("info") // info, warning, critical
  data        String?  // JSON
  isRead      Boolean  @default(false)
  isActioned  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@map("hermes_insights")
}

model ScheduledPost {
  id            String    @id @default(cuid())
  caption       String
  platforms     String    // JSON array of platform names
  productUrl    String?
  affiliateLink String?
  imageUrl      String?
  hashtags      String?   // JSON array
  status        String    @default("scheduled") // scheduled, publishing, published, failed
  scheduledAt   DateTime
  publishedAt   DateTime?
  result        String?   // JSON with platform results
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([scheduledAt])
  @@map("scheduled_posts")
}

model ContentLibrary {
  id          String   @id @default(cuid())
  type        String   // caption, script, hashtags, live_script, review, comparison
  platform    String   // tiktok, instagram, facebook, youtube, shopee_live
  niche       String?
  product     String?
  content     String
  language    String   @default("manglish") // english, bahasa, manglish
  tone        String   @default("casual") // casual, professional, excited, funny
  usageCount  Int      @default(0)
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([platform])
  @@index([createdAt])
  @@index([isFavorite])
  @@map("content_library")
}
